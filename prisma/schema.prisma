generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "postgresqlExtensions"]
  output          = "../src/generated/prisma"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector, pg_trgm]
}

model Idea {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                  String
  slug                   String    @unique
  summary                String
  detailedAnalysis       String?   @map("detailed_analysis")

  category               String
  subcategory            String?
  niches                 String[]  @default([])
  productFormat          String?   @map("product_format")
  marketplaceFit         String[]  @default([]) @map("marketplace_fit")

  status                 String    @default("pending")
  priorityScore          Float     @default(0) @map("priority_score")
  confidenceScore        Float     @default(0) @map("confidence_score")

  googleTrendsScore      Int?      @map("google_trends_score")
  googleTrendsDirection  String?   @map("google_trends_direction")
  redditMentionCount     Int       @default(0) @map("reddit_mention_count")
  redditQuestionCount    Int       @default(0) @map("reddit_question_count")
  youtubeVideoCount      Int       @default(0) @map("youtube_video_count")
  youtubeAvgViews        Int       @default(0) @map("youtube_avg_views")
  tiktokHashtagCount     Int       @default(0) @map("tiktok_hashtag_count")
  pinterestPinCount      Int       @default(0) @map("pinterest_pin_count")
  forumMentionCount      Int       @default(0) @map("forum_mention_count")
  searchVolumeMonthly    Int?      @map("search_volume_monthly")

  etsyCompetitorCount    Int       @default(0) @map("etsy_competitor_count")
  etsyAvgPrice           Float?    @map("etsy_avg_price")
  etsyAvgReviews         Int?      @map("etsy_avg_reviews")
  etsyTopSellers         Json?     @map("etsy_top_sellers")
  gumroadCompetitorCount Int       @default(0) @map("gumroad_competitor_count")
  gumroadAvgPrice        Float?    @map("gumroad_avg_price")
  whopCompetitorCount    Int       @default(0) @map("whop_competitor_count")
  creativeMarketCount    Int       @default(0) @map("creative_market_count")
  appSumoLtdExists       Boolean   @default(false) @map("appsumo_ltd_exists")

  existingProducts       Json      @default("[]") @map("existing_products")
  competitorAnalysis     String?   @map("competitor_analysis")
  differentiationNotes   String?   @map("differentiation_notes")

  estimatedPriceRange    String?   @map("estimated_price_range")
  estimatedMonthlyRev    String?   @map("estimated_monthly_rev")
  effortToBuild          String?   @map("effort_to_build")
  timeToBuild            String?   @map("time_to_build")

  sourceLinks            Json      @default("[]") @map("source_links")
  discoverySource        String?   @map("discovery_source")

  operatorNotes          String[]  @default([]) @map("operator_notes")
  declineReason          String?   @map("decline_reason")
  approvalNotes          String?   @map("approval_notes")

  embedding              Unsupported("vector(1536)")?

  discoveredAt           DateTime  @default(now()) @map("discovered_at")
  lastDataRefresh        DateTime? @map("last_data_refresh")
  statusChangedAt        DateTime? @map("status_changed_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  ideaTags               IdeaTag[]
  conversations          Conversation[]
  brainMemories          BrainMemory[]

  @@index([status])
  @@index([category])
  @@index([priorityScore(sort: Desc)])
  @@index([discoveredAt(sort: Desc)])
  @@map("ideas")
}

model BrainMemory {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memoryType    String    @map("memory_type")
  content       String
  importance    Int       @default(50)
  active        Boolean   @default(true)
  source        String?
  relatedIdeaId String?   @map("related_idea_id") @db.Uuid
  embedding     Unsupported("vector(1536)")?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  relatedIdea   Idea?     @relation(fields: [relatedIdeaId], references: [id], onDelete: SetNull)

  @@index([memoryType])
  @@index([active])
  @@index([importance(sort: Desc)])
  @@map("brain_memories")
}

model Conversation {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String?
  relatedIdeaId String?   @map("related_idea_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  relatedIdea   Idea?     @relation(fields: [relatedIdeaId], references: [id], onDelete: SetNull)
  messages      Message[]

  @@index([updatedAt(sort: Desc)])
  @@map("conversations")
}

model Message {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  role           String
  content        String
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at")

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model ScrapeLog {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source       String
  startedAt    DateTime  @default(now()) @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  itemsFound   Int       @default(0) @map("items_found")
  itemsKept    Int       @default(0) @map("items_kept")
  itemsRejected Int      @default(0) @map("items_rejected")
  status       String    @default("running")
  error        String?
  metadata     Json?

  @@index([source])
  @@index([startedAt(sort: Desc)])
  @@map("scrape_logs")
}

model MonitoredSource {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  type            String
  url             String
  enabled         Boolean   @default(true)
  frequencyHours  Int       @default(6) @map("frequency_hours")
  lastRunAt       DateTime? @map("last_run_at")
  lastSuccessAt   DateTime? @map("last_success_at")
  metadata        Json?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([type])
  @@index([enabled])
  @@map("monitored_sources")
}

model Tag {
  id       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String    @unique
  slug     String    @unique
  color    String?
  ideaTags IdeaTag[]
  @@map("tags")
}

model IdeaTag {
  ideaId String @map("idea_id") @db.Uuid
  tagId  String @map("tag_id") @db.Uuid
  idea   Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([ideaId, tagId])
  @@map("idea_tags")
}
